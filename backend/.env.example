# EZ-NEXUS AI — Backend Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default — no setup required)
DATABASE_URL=sqlite:///./ez_nexus.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/ez_nexus

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── AI Integration ────────────────────────────────────────────────────────────
# Claude AI (primary — recommended). Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI (secondary fallback — optional)
# OPENAI_API_KEY=

# ── Twilio (Real Phone Calls) ─────────────────────────────────────────────────
# Activate when client signs up. Get credentials at https://twilio.com/console
# Step 1: Create a Twilio account → get Account SID + Auth Token
# Step 2: Buy a Twilio phone number (~$1/month)
# Step 3: Fill these in → calls go through real phone network
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token_here
# TWILIO_PHONE_NUMBER=+15550001234
# TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── SMTP (Email Confirmations) ────────────────────────────────────────────────
# Works with Gmail, SendGrid, Mailgun, etc.
# Gmail: enable "App Passwords" in Google Account → Security, use that as SMTP_PASSWORD
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=youremail@gmail.com
# SMTP_PASSWORD=your_app_password_here

# ── Base URL (for approval email links) ──────────────────────────────────────
# Set this to your public domain when deploying
BASE_URL=http://localhost:8000

# ── Security ─────────────────────────────────────────────────────────────────
# JWT secret for future auth integration
SECRET_KEY=change-this-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (frontend URLs)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
